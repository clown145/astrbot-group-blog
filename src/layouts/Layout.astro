---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Astrbot Group Blog",
  description = "QQ群聊日报与长期趋势博客",
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header style="border-bottom:1px solid #ddd;background:#fff;">
      <div style="max-width:960px;margin:0 auto;padding:16px 20px;display:flex;justify-content:space-between;gap:16px;align-items:center;flex-wrap:wrap;">
        <a href="/" style="font-size:24px;font-weight:700;color:#111;text-decoration:none;">
          Astrbot Group Blog
        </a>
        <nav style="display:flex;gap:12px;flex-wrap:wrap;">
          <a href="/" style="color:#111;text-decoration:none;">首页</a>
          <a href="/login" style="color:#111;text-decoration:none;">绑定 / 登录</a>
        </nav>
      </div>
    </header>

    <slot />
  </body>
</html>
