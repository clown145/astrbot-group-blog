---
import "../styles/global.css";
import { getRuntimeEnv } from "@/lib/server/runtime-env";
import { safeGetCurrentAuthSession } from "@/lib/server/safe-auth";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Astrbot Group Blog",
  description = "QQ群聊日报与长期趋势博客",
} = Astro.props;
const env = getRuntimeEnv(Astro.locals);
const { authSession } = await safeGetCurrentAuthSession(env, Astro.cookies);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <div class="relative min-h-screen overflow-x-clip">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[14rem] bg-[radial-gradient(circle_at_top_left,rgba(30,111,92,0.16),transparent_42%),radial-gradient(circle_at_top_right,rgba(157,75,46,0.10),transparent_34%)] sm:h-[22rem]"></div>

      <header class="sticky top-0 z-30 border-b border-line/80 bg-paper/90 backdrop-blur">
        <div class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-3 py-2.5 sm:px-6 sm:py-4 lg:px-10">
          <a class="flex items-center gap-2.5 text-ink no-underline sm:gap-3" href="/">
            <span class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-line bg-white/80 font-serif text-base sm:h-10 sm:w-10 sm:text-xl">
              群
            </span>
            <span>
              <span class="block font-serif text-base leading-none sm:text-2xl">Astrbot Group Blog</span>
              <span class="mt-1 hidden text-xs uppercase tracking-[0.18em] text-ink-soft sm:block">
                Daily Reports And Living Archives
              </span>
            </span>
          </a>

          <nav class="flex min-w-0 flex-nowrap items-center justify-end gap-1.5 overflow-x-auto text-xs font-medium text-ink-soft sm:gap-2 sm:text-sm">
            <a class="rounded-full px-3 py-1.5 transition hover:bg-white/80 hover:text-ink sm:px-4 sm:py-2" href="/bind">
              绑定
            </a>
            <a class="rounded-full px-3 py-1.5 transition hover:bg-white/80 hover:text-ink sm:px-4 sm:py-2" href="/portal">
              我的博客
            </a>
            {
              authSession ? (
                <button
                  class="rounded-full border border-line bg-white/70 px-3 py-1.5 text-ink transition hover:bg-white sm:px-4 sm:py-2"
                  data-layout-logout-button
                  type="button"
                >
                  退出登录
                </button>
              ) : (
                <a class="rounded-full border border-line bg-white/70 px-3 py-1.5 text-ink transition hover:bg-white sm:px-4 sm:py-2" href="/login">
                  登录
                </a>
              )
            }
          </nav>
        </div>
      </header>

      <slot />

      <footer class="border-t border-line/80 bg-paper/70">
        <div class="mx-auto flex max-w-6xl flex-col gap-3 px-6 py-8 text-sm text-ink-soft lg:flex-row lg:items-center lg:justify-between lg:px-10">
          <p>这个站点用于承接 AstrBot 插件上传的群日报、长期趋势和历史归档。</p>
          <div class="flex flex-wrap gap-4">
            <a class="underline-offset-4 hover:underline" href="/portal">我的博客</a>
            <a class="underline-offset-4 hover:underline" href="/bind">首次绑定</a>
            <a class="underline-offset-4 hover:underline" href="/templates">模板来源</a>
            <a class="underline-offset-4 hover:underline" href="/api/health">健康检查</a>
          </div>
        </div>
      </footer>
    </div>
    <script is:inline>
      document.querySelector("[data-layout-logout-button]")?.addEventListener("click", async () => {
        await fetch("/api/auth/logout", {
          method: "POST",
          credentials: "same-origin",
          headers: {
            "content-type": "application/json",
          },
          body: "{}",
        });
        window.location.href = "/login";
      });
    </script>
  </body>
</html>
