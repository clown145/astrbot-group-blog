---
import { canViewBlog } from "@/lib/server/blog-access";
import { getBlogBySlug, getReportRouteKey } from "@/lib/server/blog-store";
import { ensureBlogSchema } from "@/lib/server/db-bootstrap";
import { getBlogHomeModel } from "@/lib/server/blog-query";
import { getCurrentAuthSession } from "@/lib/server/request";
import { getRuntimeEnv } from "@/lib/server/runtime-env";
import ActivityHeatmapChart from "../../../components/ActivityHeatmapChart";
import HourlyActivityChart from "../../../components/HourlyActivityChart";
import Layout from "../../../layouts/Layout.astro";
import MultiSeriesTrendChart from "../../../components/MultiSeriesTrendChart";
import RankingBarChart from "../../../components/RankingBarChart";

const { slug } = Astro.params;
const env = getRuntimeEnv(Astro.locals);
await ensureBlogSchema(env);
const blog = slug ? await getBlogBySlug(env, slug) : null;

if (!blog) {
  Astro.response.status = 404;
}

const current = await getCurrentAuthSession(env, Astro.cookies);
const canAccess = blog ? canViewBlog(blog, current.authSession) : false;
const homeModel = blog && canAccess ? await getBlogHomeModel(env, blog) : null;
const buildReportHref = (routeKey: string) =>
  `/g/${blog?.public_slug ?? slug}/reports/${routeKey}`;

function asRecords(value: unknown): Record<string, unknown>[] {
  if (!Array.isArray(value)) {
    return [];
  }
  return value.filter(
    (item): item is Record<string, unknown> =>
      Boolean(item) && typeof item === "object" && !Array.isArray(item),
  );
}

const latestReport = homeModel?.latestReport ?? null;
const latestView = homeModel?.latestView ?? null;
const trend = homeModel?.trend ?? [];
const derivedTrend = homeModel?.derivedTrend ?? [];
const averagedHourly = homeModel?.averagedHourly ?? [];
const heatmap = homeModel?.heatmap ?? [];
const coverageTimeline = homeModel?.coverageTimeline ?? [];
const coverageSummary = homeModel?.coverageSummary ?? {
  full: 0,
  partial: 0,
  truncated: 0,
  unknown: 0,
};
const recurringTopUsers = homeModel?.recurringTopUsers ?? [];
const recurringTopics = homeModel?.recurringTopics ?? [];
const recentReports = homeModel?.recentReports ?? [];
const topUsers = asRecords(latestView?.top_users).slice(0, 8);
const topics = asRecords(latestView?.topics).slice(0, 6);
const quotes = asRecords(latestView?.quotes).slice(0, 4);
const hourlyBuckets = asRecords(latestView?.hourly_activity);
const trendLabels = trend.map((point) => point.snapshot_date ?? "未定");
const derivedLabels = derivedTrend.map((point) => point.snapshot_date);
const peakHours = averagedHourly
  .slice()
  .sort((left, right) => right.average_message_count - left.average_message_count)
  .slice(0, 3);
const truncatedDays = coverageTimeline.filter(
  (point) => point.coverage_status === "truncated" || point.message_limit_hit,
);
const rankingItems = recurringTopUsers.slice(0, 8).map((user) => ({
  label: user.display_name,
  value: user.appearance_count,
  detail: `上榜 ${user.appearance_count} 天 · 发言 ${user.total_message_count} · 平均排名 ${user.average_rank}`,
}));
const averageCharsLatest = derivedTrend.at(-1)?.chars_per_message ?? 0;
const averageEmojiDensityLatest = derivedTrend.at(-1)?.emoji_per_100_messages ?? 0;
---

<Layout title={`群博客 | ${slug}`} description="群聊博客首页">
  <main class="mx-auto max-w-6xl px-4 py-5 sm:px-6 sm:py-8 lg:px-10 lg:py-16">
    {
      !blog ? (
        <section class="rounded-[1.6rem] border border-line bg-white/85 p-5 shadow-[var(--shadow-card)] sm:rounded-[2rem] sm:p-8">
          <p class="text-sm uppercase tracking-[0.2em] text-rust">Not Found</p>
          <h1 class="mt-3 font-serif text-3xl text-ink sm:text-4xl">这个博客不存在</h1>
          <p class="mt-3 max-w-2xl text-sm leading-7 text-ink-soft sm:text-base sm:leading-8">
            当前 slug 没有找到对应群博客。
          </p>
        </section>
      ) : !canAccess ? (
        <section class="grid gap-4 sm:gap-6 lg:grid-cols-[1.15fr_0.85fr]">
          <article class="rounded-[1.6rem] border border-line bg-white/85 p-5 shadow-[var(--shadow-card)] sm:rounded-[2rem] sm:p-8">
            <p class="text-sm uppercase tracking-[0.2em] text-rust">Group Home</p>
            <h1 class="mt-3 font-serif text-3xl text-ink sm:text-5xl">
              {blog.group_name || blog.public_slug}
            </h1>
            <p class="mt-3 max-w-3xl text-sm leading-7 text-ink-soft sm:text-base sm:leading-8">
              这个博客已启用访问控制。先完成绑定或登录，才能查看趋势、热力图和日报归档。
            </p>
            <div class="mt-5 flex flex-wrap gap-3 sm:mt-8 sm:gap-4">
              <a
                class="rounded-full bg-mint px-4 py-2.5 text-sm font-semibold text-white transition hover:opacity-90 sm:px-5 sm:py-3"
                href={`/bind?blog=${encodeURIComponent(blog.public_slug)}&next=${encodeURIComponent(`/g/${blog.public_slug}`)}`}
              >
                首次绑定
              </a>
              <a
                class="rounded-full border border-line px-4 py-2.5 text-sm font-semibold text-ink transition hover:bg-paper-strong sm:px-5 sm:py-3"
                href={`/login?next=${encodeURIComponent(`/g/${blog.public_slug}`)}`}
              >
                已有账号登录
              </a>
            </div>
          </article>

          <article class="rounded-[1.6rem] border border-line bg-paper-strong p-5 sm:rounded-[2rem] sm:p-8">
            <p class="text-xs uppercase tracking-[0.18em] text-ink-soft sm:text-sm sm:tracking-[0.2em]">Access Flow</p>
            <ol class="mt-4 space-y-3 text-sm leading-7 text-ink">
              <li>1. 绑定页默认只需要群号和你的账号 ID，平台通常可以留空。</li>
              <li>2. 获取一次性绑定码后，回群里给 bot 发送 `/绑定博客 &lt;code&gt;`。</li>
              <li>3. 回网页设置密码，系统会直接进入这个群博客或门户页。</li>
              <li>4. 后续在右上角用“我的博客”和“退出登录”完成切换。</li>
            </ol>
          </article>
        </section>
      ) : (
        <>
          <section class="grid gap-4 sm:gap-6 lg:grid-cols-[1.15fr_0.85fr]">
            <article class="rounded-[1.6rem] border border-line bg-white/85 p-5 shadow-[var(--shadow-card)] sm:rounded-[2rem] sm:p-8">
              <p class="text-sm uppercase tracking-[0.2em] text-rust">Group Home</p>
              <h1 class="mt-3 font-serif text-3xl text-ink sm:text-5xl">
                {blog.group_name || blog.public_slug}
              </h1>
              <p class="mt-3 max-w-3xl text-sm leading-7 text-ink-soft sm:text-base sm:leading-8">
                这里不是单日报告列表，而是基于近 30 天日报快照整理出来的长期群画像。
              </p>
              <div class="mt-5 flex flex-wrap gap-3 sm:mt-8 sm:gap-4">
                {
                  latestReport ? (
                    <a
                      class="rounded-full bg-mint px-4 py-2.5 text-sm font-semibold text-white transition hover:opacity-90 sm:px-5 sm:py-3"
                      href={buildReportHref(getReportRouteKey(latestReport))}
                    >
                      打开最新日报
                    </a>
                  ) : null
                }
                <a
                  class="rounded-full border border-line px-4 py-2.5 text-sm font-semibold text-ink transition hover:bg-paper-strong sm:px-5 sm:py-3"
                  href={`/g/${blog.public_slug}/archive`}
                >
                  查看全部归档
                </a>
              </div>
            </article>

            <article class="rounded-[1.6rem] border border-line bg-paper-strong p-5 sm:rounded-[2rem] sm:p-8">
              <p class="text-xs uppercase tracking-[0.18em] text-ink-soft sm:text-sm sm:tracking-[0.2em]">Latest Snapshot</p>
              <dl class="mt-4 grid gap-4 sm:mt-6 sm:grid-cols-2 sm:gap-5">
                <div>
                  <dt class="text-xs uppercase tracking-[0.16em] text-ink-soft">消息数</dt>
                  <dd class="mt-2 font-serif text-3xl text-ink sm:text-4xl">
                    {latestReport?.message_count ?? 0}
                  </dd>
                </div>
                <div>
                  <dt class="text-xs uppercase tracking-[0.16em] text-ink-soft">活跃人数</dt>
                  <dd class="mt-2 font-serif text-3xl text-ink sm:text-4xl">
                    {latestReport?.active_user_count ?? 0}
                  </dd>
                </div>
                <div>
                  <dt class="text-xs uppercase tracking-[0.16em] text-ink-soft">平均字数/条</dt>
                  <dd class="mt-2 font-serif text-3xl text-ink sm:text-4xl">
                    {averageCharsLatest.toFixed(1)}
                  </dd>
                </div>
                <div>
                  <dt class="text-xs uppercase tracking-[0.16em] text-ink-soft">表情密度/百条</dt>
                  <dd class="mt-2 font-serif text-3xl text-ink sm:text-4xl">
                    {averageEmojiDensityLatest.toFixed(1)}
                  </dd>
                </div>
              </dl>
              <div class="mt-5 rounded-[1.25rem] border border-line bg-white/80 p-4 text-sm leading-7 text-ink-soft sm:mt-8 sm:rounded-[1.5rem] sm:p-5">
                最近日期：<span class="font-semibold text-ink">{latestReport?.snapshot_date ?? "暂无"}</span>
                <br />
                最近高峰：<span class="font-semibold text-ink">{latestReport?.most_active_period || "暂无"}</span>
              </div>
            </article>
          </section>

          <section class="mt-5 grid gap-4 sm:mt-8 sm:gap-6 lg:grid-cols-2">
            <article class="rounded-[1.6rem] border border-line bg-white/85 p-5 shadow-[var(--shadow-card)] sm:rounded-[2rem] sm:p-8">
              <p class="text-sm uppercase tracking-[0.2em] text-rust">Thirty Days</p>
              <h2 class="mt-3 font-serif text-xl text-ink sm:mt-4 sm:text-3xl">消息量、参与人数、活跃人数</h2>
              {
                trend.length ? (
                  <div class="mt-4 rounded-[1.25rem] bg-paper p-3 sm:mt-6 sm:rounded-[1.5rem]">
                    <MultiSeriesTrendChart
                      labels={trendLabels}
                      series={[
                        {
                          name: "消息数",
                          data: trend.map((point) => point.message_count),
                          color: "#1e6f5c",
                        },
                        {
                          name: "参与人数",
                          data: trend.map((point) => point.participant_count),
                          color: "#9d4b2e",
                        },
                        {
                          name: "活跃人数",
                          data: trend.map((point) => point.active_user_count),
                          color: "#5b7c6a",
                        },
                      ]}
                      client:visible
                    />
                  </div>
                ) : (
                  <p class="mt-4 text-sm leading-7 text-ink-soft sm:mt-6 sm:text-base sm:leading-8">
                    还没有足够的正式日报快照，趋势会随着每日归档逐步出现。
                  </p>
                )
              }
            </article>

            <article class="rounded-[1.6rem] border border-line bg-white/85 p-5 shadow-[var(--shadow-card)] sm:rounded-[2rem] sm:p-8">
              <p class="text-sm uppercase tracking-[0.2em] text-rust">Density</p>
              <h2 class="mt-3 font-serif text-xl text-ink sm:mt-4 sm:text-3xl">平均字数与表情密度</h2>
              {
                derivedTrend.length ? (
                  <div class="mt-4 rounded-[1.25rem] bg-paper p-3 sm:mt-6 sm:rounded-[1.5rem]">
                    <MultiSeriesTrendChart
                      labels={derivedLabels}
                      series={[
                        {
                          name: "平均字数/条",
                          data: derivedTrend.map((point) => point.chars_per_message),
                          color: "#1e6f5c",
                        },
                        {
                          name: "表情/百条",
                          data: derivedTrend.map((point) => point.emoji_per_100_messages),
                          color: "#d2764b",
                        },
                      ]}
                      client:visible
                    />
                  </div>
                ) : (
                  <p class="mt-4 text-sm leading-7 text-ink-soft sm:mt-6 sm:text-base sm:leading-8">
                    还没有足够的数据生成密度趋势。
                  </p>
                )
              }
            </article>
          </section>

          <section class="mt-5 grid gap-4 sm:mt-8 sm:gap-6 lg:grid-cols-[1.1fr_0.9fr]">
            <article class="rounded-[1.6rem] border border-line bg-white/85 p-5 shadow-[var(--shadow-card)] sm:rounded-[2rem] sm:p-8">
              <p class="text-sm uppercase tracking-[0.2em] text-rust">Heatmap</p>
              <h2 class="mt-3 font-serif text-xl text-ink sm:mt-4 sm:text-3xl">近 30 天活跃热力图</h2>
              {
                heatmap.length ? (
                  <div class="mt-4 rounded-[1.25rem] bg-paper p-3 sm:mt-6 sm:rounded-[1.5rem]">
                    <ActivityHeatmapChart cells={heatmap} client:visible />
                  </div>
                ) : (
                  <p class="mt-4 text-sm leading-7 text-ink-soft sm:mt-6 sm:text-base sm:leading-8">
                    当前没有足够的小时分布数据。
                  </p>
                )
              }
            </article>

            <article class="rounded-[1.6rem] border border-line bg-white/85 p-5 shadow-[var(--shadow-card)] sm:rounded-[2rem] sm:p-8">
              <p class="text-sm uppercase tracking-[0.2em] text-rust">Average Hour</p>
              <h2 class="mt-3 font-serif text-xl text-ink sm:mt-4 sm:text-3xl">平均 24 小时分布</h2>
              {
                averagedHourly.length ? (
                  <>
                    <div class="mt-4 rounded-[1.25rem] bg-paper p-3 sm:mt-6 sm:rounded-[1.5rem]">
                      <HourlyActivityChart
                        buckets={averagedHourly.map((bucket) => ({
                          hour: bucket.hour,
                          message_count: bucket.average_message_count,
                        }))}
                        client:visible
                      />
                    </div>
                    <div class="mt-5 grid gap-3 sm:mt-6">
                      {peakHours.map((bucket, index) => (
                        <div class="rounded-[1.1rem] border border-line bg-paper-strong px-4 py-3 text-sm text-ink sm:text-base">
                          <div class="text-xs uppercase tracking-[0.14em] text-rust">Peak {index + 1}</div>
                          <div class="mt-1 font-semibold text-ink">
                            {String(bucket.hour).padStart(2, "0")}:00
                          </div>
                          <div class="mt-1 text-ink-soft">
                            平均 {bucket.average_message_count.toFixed(1)} 条
                          </div>
                        </div>
                      ))}
                    </div>
                  </>
                ) : (
                  <p class="mt-4 text-sm leading-7 text-ink-soft sm:mt-6 sm:text-base sm:leading-8">
                    当前最新日报没有小时分布数据。
                  </p>
                )
              }
            </article>
          </section>

          <section class="mt-5 grid gap-4 sm:mt-8 sm:gap-6 lg:grid-cols-[0.95fr_1.05fr]">
            <article class="rounded-[1.6rem] border border-line bg-white/85 p-5 shadow-[var(--shadow-card)] sm:rounded-[2rem] sm:p-8">
              <p class="text-sm uppercase tracking-[0.2em] text-rust">Coverage</p>
              <h2 class="mt-3 font-serif text-xl text-ink sm:mt-4 sm:text-3xl">覆盖质量</h2>
              <div class="mt-4 grid grid-cols-2 gap-3 sm:mt-6 sm:grid-cols-4">
                <div class="rounded-[1.1rem] bg-paper-strong px-4 py-3">
                  <div class="text-xs uppercase tracking-[0.14em] text-ink-soft">完整</div>
                  <div class="mt-2 font-serif text-3xl text-ink">{coverageSummary.full}</div>
                </div>
                <div class="rounded-[1.1rem] bg-paper-strong px-4 py-3">
                  <div class="text-xs uppercase tracking-[0.14em] text-ink-soft">部分</div>
                  <div class="mt-2 font-serif text-3xl text-ink">{coverageSummary.partial}</div>
                </div>
                <div class="rounded-[1.1rem] bg-paper-strong px-4 py-3">
                  <div class="text-xs uppercase tracking-[0.14em] text-ink-soft">截断</div>
                  <div class="mt-2 font-serif text-3xl text-ink">{coverageSummary.truncated}</div>
                </div>
                <div class="rounded-[1.1rem] bg-paper-strong px-4 py-3">
                  <div class="text-xs uppercase tracking-[0.14em] text-ink-soft">未知</div>
                  <div class="mt-2 font-serif text-3xl text-ink">{coverageSummary.unknown}</div>
                </div>
              </div>
              <div class="mt-5 rounded-[1.25rem] border border-line bg-paper p-4 sm:mt-6 sm:rounded-[1.5rem] sm:p-5">
                <div class="text-xs uppercase tracking-[0.16em] text-ink-soft">需要注意的日期</div>
                {
                  truncatedDays.length ? (
                    <div class="mt-3 flex flex-wrap gap-2">
                      {truncatedDays.slice(-8).map((point) => (
                        <span class="rounded-full border border-line bg-white px-3 py-1.5 text-xs text-ink">
                          {point.date}
                        </span>
                      ))}
                    </div>
                  ) : (
                    <p class="mt-3 text-sm leading-7 text-ink-soft">
                      最近 30 天没有明显的截断日报。
                    </p>
                  )
                }
              </div>
            </article>

            <article class="rounded-[1.6rem] border border-line bg-white/85 p-5 shadow-[var(--shadow-card)] sm:rounded-[2rem] sm:p-8">
              <p class="text-sm uppercase tracking-[0.2em] text-rust">Recurring Members</p>
              <h2 class="mt-3 font-serif text-xl text-ink sm:mt-4 sm:text-3xl">常驻活跃成员</h2>
              {
                rankingItems.length ? (
                  <div class="mt-4 rounded-[1.25rem] bg-paper p-3 sm:mt-6 sm:rounded-[1.5rem]">
                    <RankingBarChart items={rankingItems} client:visible />
                  </div>
                ) : (
                  <p class="mt-4 text-sm leading-7 text-ink-soft sm:mt-6 sm:text-base sm:leading-8">
                    当前还没有足够的数据统计常驻活跃成员。
                  </p>
                )
              }
            </article>
          </section>

          <section class="mt-5 grid gap-4 sm:mt-8 sm:gap-6 lg:grid-cols-[0.95fr_1.05fr]">
            <article class="rounded-[1.6rem] border border-line bg-white/85 p-5 shadow-[var(--shadow-card)] sm:rounded-[2rem] sm:p-8">
              <p class="text-sm uppercase tracking-[0.2em] text-rust">Latest Leaders</p>
              <h2 class="mt-3 font-serif text-xl text-ink sm:mt-4 sm:text-3xl">最新日报活跃成员</h2>
              {
                topUsers.length ? (
                  <div class="mt-4 space-y-3 sm:mt-6 sm:space-y-4">
                    {topUsers.map((user, index) => (
                      <div class="flex items-start justify-between gap-4 rounded-[1.2rem] bg-paper-strong px-4 py-4">
                        <div class="min-w-0">
                          <div class="text-xs uppercase tracking-[0.14em] text-rust">
                            #{index + 1}
                          </div>
                          <div class="mt-2 text-base font-semibold text-ink sm:text-lg">
                            {String(user.display_name ?? "未知成员")}
                          </div>
                          <div class="mt-1 text-sm text-ink-soft">
                            发言 {Number(user.message_count ?? 0)} · 表情 {Number(user.emoji_count ?? 0)} · 回复 {Number(user.reply_count ?? 0)}
                          </div>
                        </div>
                        <div class="text-right text-sm text-ink-soft">
                          <div>字符 {Number(user.char_count ?? 0)}</div>
                          <div class="mt-1">
                            夜聊占比 {(Number(user.night_ratio ?? 0) * 100).toFixed(1)}%
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                ) : (
                  <p class="mt-4 text-sm leading-7 text-ink-soft sm:mt-6 sm:text-base sm:leading-8">
                    当前最新日报没有成员榜单数据。
                  </p>
                )
              }
            </article>

            <article class="rounded-[1.6rem] border border-line bg-white/85 p-5 shadow-[var(--shadow-card)] sm:rounded-[2rem] sm:p-8">
              <p class="text-sm uppercase tracking-[0.2em] text-rust">Highlights</p>
              <h2 class="mt-3 font-serif text-xl text-ink sm:mt-4 sm:text-3xl">热话题与金句</h2>
              <div class="mt-4 grid gap-4 sm:mt-6 sm:gap-6 lg:grid-cols-2">
                <div>
                  <h3 class="text-sm uppercase tracking-[0.14em] text-ink-soft">近 30 天常见话题</h3>
                  {
                    recurringTopics.length ? (
                      <div class="mt-3 flex flex-wrap gap-2">
                        {recurringTopics.map((topic) => (
                          <span class="rounded-full border border-line bg-paper px-3 py-1.5 text-xs text-ink sm:text-sm">
                            {topic.name} · {topic.occurrence_count}
                          </span>
                        ))}
                      </div>
                    ) : (
                      <p class="mt-3 text-sm leading-7 text-ink-soft">当前没有足够的话题样本。</p>
                    )
                  }
                  <h3 class="mt-5 text-sm uppercase tracking-[0.14em] text-ink-soft sm:mt-6">今日话题</h3>
                  {
                    topics.length ? (
                      <div class="mt-3 space-y-3 sm:space-y-4">
                        {topics.map((topic, index) => (
                          <article class="rounded-[1.2rem] bg-paper-strong px-4 py-4">
                            <div class="text-xs uppercase tracking-[0.14em] text-rust">
                              #{index + 1}
                            </div>
                            <h4 class="mt-2 text-base font-semibold text-ink sm:text-lg">
                              {String(topic.name ?? "未命名话题")}
                            </h4>
                            <p class="mt-2 text-sm leading-7 text-ink-soft" set:html={String(topic.detail ?? "")}></p>
                          </article>
                        ))}
                      </div>
                    ) : (
                      <p class="mt-3 text-sm leading-7 text-ink-soft">当前没有话题摘要。</p>
                    )
                  }
                </div>

                <div>
                  <h3 class="text-sm uppercase tracking-[0.14em] text-ink-soft">群圣经</h3>
                  {
                    quotes.length ? (
                      <div class="mt-3 space-y-3 sm:space-y-4">
                        {quotes.map((quote) => (
                          <blockquote class="rounded-[1.2rem] bg-paper-strong px-4 py-4 text-sm leading-7 text-ink">
                            <div class="font-semibold text-ink">
                              {String(quote.sender ?? "未知成员")}
                            </div>
                            <p class="mt-2">“{String(quote.content ?? "")}”</p>
                            <footer class="mt-3 text-ink-soft" set:html={String(quote.reason ?? "")}></footer>
                          </blockquote>
                        ))}
                      </div>
                    ) : (
                      <p class="mt-3 text-sm leading-7 text-ink-soft">当前没有归档金句。</p>
                    )
                  }
                </div>
              </div>
            </article>
          </section>

          <section class="mt-5 rounded-[1.6rem] border border-line bg-white/85 p-5 shadow-[var(--shadow-card)] sm:mt-8 sm:rounded-[2rem] sm:p-8">
            <div class="flex flex-wrap items-end justify-between gap-4">
              <div>
                <p class="text-sm uppercase tracking-[0.2em] text-rust">Recent Reports</p>
                <h2 class="mt-3 font-serif text-xl text-ink sm:mt-4 sm:text-3xl">最近归档</h2>
              </div>
              <a
                class="text-sm font-semibold text-mint underline-offset-4 hover:underline"
                href={`/g/${blog.public_slug}/archive`}
              >
                查看完整归档
              </a>
            </div>
            {
              recentReports.length ? (
                <div class="mt-4 grid gap-3 sm:mt-6 sm:gap-4 md:grid-cols-2">
                  {recentReports.map((report) => (
                    <a
                      class="rounded-[1.2rem] border border-line bg-paper-strong px-4 py-4 transition hover:-translate-y-0.5 hover:shadow-[var(--shadow-card)]"
                      href={buildReportHref(getReportRouteKey(report))}
                    >
                      <div class="text-xs uppercase tracking-[0.14em] text-rust">
                        {report.report_kind}
                      </div>
                      <div class="mt-2 text-base font-semibold text-ink sm:text-lg">
                        {report.snapshot_date ?? report.generated_at.slice(0, 10)}
                      </div>
                      <div class="mt-2 text-sm text-ink-soft">
                        消息 {report.message_count} · 参与 {report.participant_count}
                      </div>
                    </a>
                  ))}
                </div>
              ) : (
                <p class="mt-4 text-sm leading-7 text-ink-soft sm:mt-6 sm:text-base sm:leading-8">
                  还没有归档报告。
                </p>
              )
            }
          </section>
        </>
      )
    }
  </main>
</Layout>
