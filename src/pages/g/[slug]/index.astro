---
import { canViewBlog } from "@/lib/server/blog-access";
import {
  getBlogBySlug,
  getReportRouteKey,
} from "@/lib/server/blog-store";
import { ensureBlogSchema } from "@/lib/server/db-bootstrap";
import { getBlogHomeModel } from "@/lib/server/blog-query";
import { getCurrentAuthSession } from "@/lib/server/request";
import { getRuntimeEnv } from "@/lib/server/runtime-env";
import HourlyActivityChart from "../../../components/HourlyActivityChart";
import Layout from "../../../layouts/Layout.astro";
import TrendLineChart from "../../../components/TrendLineChart";

const { slug } = Astro.params;
const env = getRuntimeEnv(Astro.locals);
await ensureBlogSchema(env);
const blog = slug ? await getBlogBySlug(env, slug) : null;

if (!blog) {
  Astro.response.status = 404;
}

const current = await getCurrentAuthSession(env, Astro.cookies);
const canAccess = blog ? canViewBlog(blog, current.authSession) : false;
const homeModel = blog && canAccess ? await getBlogHomeModel(env, blog) : null;

function asRecords(value: unknown): Record<string, unknown>[] {
  if (!Array.isArray(value)) {
    return [];
  }
  return value.filter(
    (item): item is Record<string, unknown> =>
      Boolean(item) && typeof item === "object" && !Array.isArray(item),
  );
}

const latestReport = homeModel?.latestReport ?? null;
const latestView = homeModel?.latestView ?? null;
const trend = homeModel?.trend ?? [];
const recentReports = homeModel?.recentReports ?? [];
const topUsers = asRecords(latestView?.top_users).slice(0, 8);
const topics = asRecords(latestView?.topics).slice(0, 6);
const quotes = asRecords(latestView?.quotes).slice(0, 4);
const hourlyBuckets = asRecords(latestView?.hourly_activity);
---

<Layout title={`群博客 | ${slug}`} description="群聊博客首页">
  <main class="mx-auto max-w-6xl px-6 py-16 lg:px-10">
    {
      !blog ? (
        <section class="rounded-[2rem] border border-line bg-white/85 p-8 shadow-[var(--shadow-card)]">
          <p class="text-sm uppercase tracking-[0.2em] text-rust">Not Found</p>
          <h1 class="mt-4 font-serif text-4xl text-ink">这个博客不存在</h1>
          <p class="mt-4 max-w-2xl text-base leading-8 text-ink-soft">
            当前 slug 没有找到对应群博客。
          </p>
        </section>
      ) : !canAccess ? (
        <section class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
          <article class="rounded-[2rem] border border-line bg-white/85 p-8 shadow-[var(--shadow-card)]">
            <p class="text-sm uppercase tracking-[0.2em] text-rust">Group Home</p>
            <h1 class="mt-4 font-serif text-5xl text-ink">
              {blog.group_name || blog.public_slug}
            </h1>
            <p class="mt-4 max-w-3xl text-base leading-8 text-ink-soft">
              这个博客已启用访问控制。你需要先绑定 QQ 账号并登录，才能查看群聊趋势和日报归档。
            </p>
            <div class="mt-8 flex flex-wrap gap-4">
              <a
                class="rounded-full bg-mint px-5 py-3 text-sm font-semibold text-white transition hover:opacity-90"
                href={`/bind?blog=${encodeURIComponent(blog.public_slug)}&next=${encodeURIComponent(`/g/${blog.public_slug}`)}`}
              >
                首次绑定
              </a>
              <a
                class="rounded-full border border-line px-5 py-3 text-sm font-semibold text-ink transition hover:bg-paper-strong"
                href={`/login?next=${encodeURIComponent(`/g/${blog.public_slug}`)}`}
              >
                已有账号登录
              </a>
            </div>
          </article>

          <article class="rounded-[2rem] border border-line bg-paper-strong p-8">
            <p class="text-sm uppercase tracking-[0.2em] text-ink-soft">Access Flow</p>
            <ol class="mt-4 space-y-3 text-sm leading-7 text-ink">
              <li>1. 在绑定页填写平台、群聊 ID 和你的平台账号 ID</li>
              <li>2. 去对应群里给 bot 发送一次性绑定码</li>
              <li>3. 回到网页设置密码，系统会直接进入这个群博客</li>
              <li>4. 后续直接用平台账号 ID + 密码进入多个已绑定群博客</li>
            </ol>
          </article>
        </section>
      ) : (
        <>
          <section class="grid gap-6 lg:grid-cols-[1.15fr_0.85fr]">
            <article class="rounded-[2rem] border border-line bg-white/85 p-8 shadow-[var(--shadow-card)]">
              <p class="text-sm uppercase tracking-[0.2em] text-rust">Group Home</p>
              <h1 class="mt-4 font-serif text-5xl text-ink">
                {blog.group_name || blog.public_slug}
              </h1>
              <p class="mt-4 max-w-3xl text-base leading-8 text-ink-soft">
                这里展示最近归档中的群聊概览、日趋势、活跃时段与画像摘要。
              </p>
              {
                latestReport ? (
                  <div class="mt-8 flex flex-wrap gap-4">
                    <a
                      class="rounded-full bg-mint px-5 py-3 text-sm font-semibold text-white transition hover:opacity-90"
                      href={`/g/${blog.public_slug}/reports/${getReportRouteKey(latestReport)}`}
                    >
                      打开最新日报
                    </a>
                    <a
                      class="rounded-full border border-line px-5 py-3 text-sm font-semibold text-ink transition hover:bg-paper-strong"
                      href={`/g/${blog.public_slug}/archive`}
                    >
                      查看全部归档
                    </a>
                  </div>
                ) : null
              }
            </article>

            <article class="rounded-[2rem] border border-line bg-paper-strong p-8">
              <p class="text-sm uppercase tracking-[0.2em] text-ink-soft">Latest Snapshot</p>
              <dl class="mt-6 grid gap-5 sm:grid-cols-2">
                <div>
                  <dt class="text-xs uppercase tracking-[0.16em] text-ink-soft">消息数</dt>
                  <dd class="mt-2 font-serif text-4xl text-ink">
                    {latestReport?.message_count ?? 0}
                  </dd>
                </div>
                <div>
                  <dt class="text-xs uppercase tracking-[0.16em] text-ink-soft">参与人数</dt>
                  <dd class="mt-2 font-serif text-4xl text-ink">
                    {latestReport?.participant_count ?? 0}
                  </dd>
                </div>
                <div>
                  <dt class="text-xs uppercase tracking-[0.16em] text-ink-soft">活跃用户</dt>
                  <dd class="mt-2 font-serif text-4xl text-ink">
                    {latestReport?.active_user_count ?? 0}
                  </dd>
                </div>
                <div>
                  <dt class="text-xs uppercase tracking-[0.16em] text-ink-soft">最近日期</dt>
                  <dd class="mt-2 text-lg font-semibold text-ink">
                    {latestReport?.snapshot_date ?? "暂无"}
                  </dd>
                </div>
              </dl>
            </article>
          </section>

          <section class="mt-8 grid gap-6 lg:grid-cols-[1.15fr_0.85fr]">
            <article class="rounded-[2rem] border border-line bg-white/85 p-8 shadow-[var(--shadow-card)]">
              <p class="text-sm uppercase tracking-[0.2em] text-rust">Thirty Days</p>
              <h2 class="mt-4 font-serif text-3xl text-ink">最近日报趋势</h2>
              {
                trend.length ? (
                  <div class="mt-6 rounded-[1.5rem] bg-paper p-3">
                    <TrendLineChart points={trend.slice().reverse()} client:visible />
                  </div>
                ) : (
                  <p class="mt-6 text-base leading-8 text-ink-soft">
                    还没有足够的正式日报快照，趋势会随着每日归档逐步出现。
                  </p>
                )
              }
            </article>

            <article class="rounded-[2rem] border border-line bg-white/85 p-8 shadow-[var(--shadow-card)]">
              <p class="text-sm uppercase tracking-[0.2em] text-rust">Hourly Activity</p>
              <h2 class="mt-4 font-serif text-3xl text-ink">24 小时分布</h2>
              {
                hourlyBuckets.length ? (
                  <div class="mt-6 rounded-[1.5rem] bg-paper p-3">
                    <HourlyActivityChart buckets={hourlyBuckets} client:visible />
                  </div>
                ) : (
                  <p class="mt-6 text-base leading-8 text-ink-soft">
                    当前最新日报没有小时分布数据。
                  </p>
                )
              }
            </article>
          </section>

          <section class="mt-8 grid gap-6 lg:grid-cols-[0.95fr_1.05fr]">
            <article class="rounded-[2rem] border border-line bg-white/85 p-8 shadow-[var(--shadow-card)]">
              <p class="text-sm uppercase tracking-[0.2em] text-rust">Top Users</p>
              <h2 class="mt-4 font-serif text-3xl text-ink">活跃成员</h2>
              {
                topUsers.length ? (
                  <div class="mt-6 space-y-4">
                    {topUsers.map((user, index) => (
                      <div class="flex items-start justify-between gap-4 rounded-2xl bg-paper-strong px-4 py-4">
                        <div>
                          <div class="text-xs uppercase tracking-[0.14em] text-rust">
                            #{index + 1}
                          </div>
                          <div class="mt-2 text-lg font-semibold text-ink">
                            {String(user.display_name ?? "未知成员")}
                          </div>
                          <div class="mt-1 text-sm text-ink-soft">
                            发言 {Number(user.message_count ?? 0)} 条 · 表情{" "}
                            {Number(user.emoji_count ?? 0)} 个 · 回复{" "}
                            {Number(user.reply_count ?? 0)} 次
                          </div>
                        </div>
                        <div class="text-right text-sm text-ink-soft">
                          <div>字符 {Number(user.char_count ?? 0)}</div>
                          <div class="mt-1">
                            夜聊占比 {(Number(user.night_ratio ?? 0) * 100).toFixed(1)}%
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                ) : (
                  <p class="mt-6 text-base leading-8 text-ink-soft">
                    当前最新日报没有成员榜单数据。
                  </p>
                )
              }
            </article>

            <article class="rounded-[2rem] border border-line bg-white/85 p-8 shadow-[var(--shadow-card)]">
              <p class="text-sm uppercase tracking-[0.2em] text-rust">Highlights</p>
              <h2 class="mt-4 font-serif text-3xl text-ink">话题与金句</h2>
              <div class="mt-6 grid gap-6 lg:grid-cols-2">
                <div>
                  <h3 class="text-sm uppercase tracking-[0.14em] text-ink-soft">
                    今日话题
                  </h3>
                  {
                    topics.length ? (
                      <div class="mt-4 space-y-4">
                        {topics.map((topic, index) => (
                          <article class="rounded-2xl bg-paper-strong px-4 py-4">
                            <div class="text-xs uppercase tracking-[0.14em] text-rust">
                              #{index + 1}
                            </div>
                            <h4 class="mt-2 text-lg font-semibold text-ink">
                              {String(topic.name ?? "未命名话题")}
                            </h4>
                            <p class="mt-2 text-sm leading-7 text-ink-soft">
                              {String(topic.detail ?? "")}
                            </p>
                          </article>
                        ))}
                      </div>
                    ) : (
                      <p class="mt-4 text-sm leading-7 text-ink-soft">
                        当前没有话题摘要。
                      </p>
                    )
                  }
                </div>
                <div>
                  <h3 class="text-sm uppercase tracking-[0.14em] text-ink-soft">
                    群圣经
                  </h3>
                  {
                    quotes.length ? (
                      <div class="mt-4 space-y-4">
                        {quotes.map((quote) => (
                          <blockquote class="rounded-2xl bg-paper-strong px-4 py-4 text-sm leading-7 text-ink">
                            <div class="font-semibold text-ink">
                              {String(quote.sender ?? "未知成员")}
                            </div>
                            <p class="mt-2">“{String(quote.content ?? "")}”</p>
                            <footer class="mt-3 text-ink-soft">
                              {String(quote.reason ?? "")}
                            </footer>
                          </blockquote>
                        ))}
                      </div>
                    ) : (
                      <p class="mt-4 text-sm leading-7 text-ink-soft">
                        当前没有归档金句。
                      </p>
                    )
                  }
                </div>
              </div>
            </article>
          </section>

          <section class="mt-8 rounded-[2rem] border border-line bg-white/85 p-8 shadow-[var(--shadow-card)]">
            <div class="flex flex-wrap items-end justify-between gap-4">
              <div>
                <p class="text-sm uppercase tracking-[0.2em] text-rust">Recent Reports</p>
                <h2 class="mt-4 font-serif text-3xl text-ink">最近归档</h2>
              </div>
              <a
                class="text-sm font-semibold text-mint underline-offset-4 hover:underline"
                href={`/g/${blog.public_slug}/archive`}
              >
                查看完整归档
              </a>
            </div>
            {
              recentReports.length ? (
                <div class="mt-6 grid gap-4 md:grid-cols-2">
                  {recentReports.map((report) => (
                    <a
                      class="rounded-2xl border border-line bg-paper-strong px-5 py-4 transition hover:-translate-y-0.5 hover:shadow-[var(--shadow-card)]"
                      href={`/g/${blog.public_slug}/reports/${getReportRouteKey(report)}`}
                    >
                      <div class="text-xs uppercase tracking-[0.14em] text-rust">
                        {report.report_kind}
                      </div>
                      <div class="mt-2 text-lg font-semibold text-ink">
                        {report.snapshot_date ?? report.generated_at.slice(0, 10)}
                      </div>
                      <div class="mt-2 text-sm text-ink-soft">
                        消息 {report.message_count} · 参与 {report.participant_count}
                      </div>
                    </a>
                  ))}
                </div>
              ) : (
                <p class="mt-6 text-base leading-8 text-ink-soft">
                  还没有归档报告。
                </p>
              )
            }
          </section>
        </>
      )
    }
  </main>
</Layout>
