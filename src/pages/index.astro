---
import { getCurrentAuthSession } from "@/lib/server/request";
import { getRuntimeEnv } from "@/lib/server/runtime-env";
import StackGrid from "../components/StackGrid";
import Layout from "../layouts/Layout.astro";

const env = getRuntimeEnv(Astro.locals);
const current = await getCurrentAuthSession(env, Astro.cookies);

const stackSections = [
  {
    title: "框架",
    items: ["Astro SSR on Workers", "React islands", "Tailwind 4"],
  },
  {
    title: "数据层",
    items: ["D1 for query data", "KV for cache", "R2 for archives"],
  },
  {
    title: "功能层",
    items: ["群博客首页", "历史日报归档", "绑定登录与群切换"],
  },
];

const milestones = [
  "接入插件 publish payload，先打通 ingest。",
  "完成绑定登录、群首页和日报归档三条主路由。",
  "再补图表、排行榜、近 30 天活跃热力图。",
];
---

<Layout title="Astrbot Group Blog" description="群聊日报与趋势博客 Worker 端">
  <main class="min-h-screen">
    <section class="border-b border-line">
      <div class="mx-auto grid max-w-6xl gap-10 px-6 py-14 lg:grid-cols-[1.25fr_0.75fr] lg:px-10 lg:py-20">
        <div class="space-y-7">
          <div class="flex flex-wrap gap-3 text-sm text-ink-soft">
            <span class="rounded-full border border-line bg-white/70 px-3 py-1">Astrbot</span>
            <span class="rounded-full border border-line bg-white/70 px-3 py-1">Cloudflare Workers</span>
            <span class="rounded-full border border-line bg-white/70 px-3 py-1">Editorial Data Blog</span>
          </div>

          <div class="space-y-5">
            <p class="font-serif text-sm uppercase tracking-[0.28em] text-rust">
              Group Daily Analysis Portal
            </p>
            <h1 class="max-w-3xl font-serif text-5xl leading-none text-ink sm:text-6xl lg:text-7xl">
              把群聊日报变成一个可长期浏览的数据博客。
            </h1>
            <p class="max-w-2xl text-lg leading-8 text-ink-soft">
              这套仓库不负责重新分析消息，而是负责承接插件上传的结构化结果，生成群首页、历史日报归档和登录后的群切换体验。
            </p>
          </div>

          <div class="flex flex-wrap gap-4">
            <a
              class="inline-flex items-center rounded-full bg-mint px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#195a4b]"
              href={current.authSession ? "#portal" : "/login"}
            >
              {current.authSession ? "进入群切换入口" : "去绑定 / 登录"}
            </a>
            <a
              class="inline-flex items-center rounded-full border border-line bg-white/80 px-5 py-3 text-sm font-semibold text-ink transition hover:bg-paper-strong"
              href="#milestones"
            >
              查看首版范围
            </a>
          </div>
        </div>

        <div class="grid gap-4">
          <article class="rounded-[1.75rem] border border-line bg-white/85 p-6 shadow-[var(--shadow-card)]">
            <p class="text-sm uppercase tracking-[0.2em] text-ink-soft">定位</p>
            <p class="mt-4 font-serif text-3xl text-ink">编辑部数据博客</p>
            <p class="mt-4 text-sm leading-7 text-ink-soft">
              不是纯后台 dashboard，也不是花哨模板站。首页重点展示长期趋势、日报归档和群画像，视觉上更像一本持续更新的群刊。
            </p>
          </article>

          <article class="rounded-[1.75rem] border border-line bg-paper-strong p-6">
            <p class="text-sm uppercase tracking-[0.2em] text-ink-soft">原则</p>
            <ul class="mt-4 space-y-3 text-sm leading-7 text-ink">
              <li>尽量用现成框架与组件，不重头造 UI 轮子。</li>
              <li>交互只放在必要位置，页面主体保持 SSR 内容站结构。</li>
              <li>主题走纸面感、档案感，而不是普通 SaaS 面板。</li>
            </ul>
          </article>
        </div>
      </div>
    </section>

    <section id="portal" class="mx-auto max-w-6xl px-6 py-14 lg:px-10">
      <div class="mb-8 flex items-end justify-between gap-6">
        <div>
          <p class="text-sm uppercase tracking-[0.2em] text-rust">Portal</p>
          <h2 class="mt-3 font-serif text-4xl text-ink">当前会话与群切换</h2>
        </div>
        <p class="max-w-xl text-sm leading-7 text-ink-soft">
          登录后可以直接从这里进入你已经绑定的群博客；未登录时，这里会展示绑定说明。
        </p>
      </div>

      {
        current.authSession ? (
          <div class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
            <article class="rounded-[1.75rem] border border-line bg-white/85 p-6 shadow-[var(--shadow-card)]">
              <p class="text-sm uppercase tracking-[0.2em] text-rust">Session</p>
              <h3 class="mt-4 font-serif text-3xl text-ink">
                QQ {current.authSession.account.qq_number}
              </h3>
              <p class="mt-4 text-sm leading-7 text-ink-soft">
                当前会话已建立，你可以直接打开已绑定的群博客，或去登录页管理会话。
              </p>
              <a
                class="mt-6 inline-flex rounded-full bg-mint px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#195a4b]"
                href="/login"
              >
                管理会话
              </a>
            </article>

            <article class="rounded-[1.75rem] border border-line bg-white/85 p-6 shadow-[var(--shadow-card)]">
              <p class="text-sm uppercase tracking-[0.2em] text-rust">Memberships</p>
              <h3 class="mt-4 font-serif text-3xl text-ink">已绑定群博客</h3>
              <div class="mt-6 grid gap-4 md:grid-cols-2">
                {current.authSession.memberships.length ? current.authSession.memberships.map((membership) => (
                  <a
                    class="rounded-[1.5rem] border border-line bg-paper-strong p-5 transition hover:-translate-y-0.5 hover:shadow-[var(--shadow-card)]"
                    href={`/g/${membership.public_slug}`}
                  >
                    <div class="text-xs uppercase tracking-[0.14em] text-rust">
                      {membership.platform}
                    </div>
                    <div class="mt-3 text-xl font-semibold text-ink">
                      {membership.group_name || membership.public_slug}
                    </div>
                    <div class="mt-2 text-sm text-ink-soft">
                      slug: {membership.public_slug}
                    </div>
                  </a>
                )) : (
                  <div class="rounded-[1.5rem] border border-line bg-paper-strong p-5 text-sm leading-7 text-ink-soft">
                    当前账号还没有已绑定的群博客。
                  </div>
                )}
              </div>
            </article>
          </div>
        ) : (
          <div class="grid gap-6 lg:grid-cols-[1fr_1fr]">
            <article class="rounded-[1.75rem] border border-line bg-white/85 p-6 shadow-[var(--shadow-card)]">
              <p class="text-sm uppercase tracking-[0.2em] text-rust">Next Step</p>
              <h3 class="mt-4 font-serif text-3xl text-ink">先绑定，再进入群博客</h3>
              <p class="mt-4 text-sm leading-7 text-ink-soft">
                第一次使用时，你需要在网页登录页发起绑定，拿到一次性绑定码后去群里给 bot 发送，然后再回来设置密码。
              </p>
              <a
                class="mt-6 inline-flex rounded-full bg-mint px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#195a4b]"
                href="/login"
              >
                去登录页
              </a>
            </article>

            <article class="rounded-[1.75rem] border border-line bg-paper-strong p-6">
              <p class="text-sm uppercase tracking-[0.2em] text-ink-soft">Flow</p>
              <ol class="mt-4 space-y-3 text-sm leading-7 text-ink">
                <li>1. 输入群博客 slug 和你的 QQ 号，获取绑定码。</li>
                <li>2. 在对应群里给 bot 发送一次性绑定码。</li>
                <li>3. 回网页设置密码，建立 Cookie 会话。</li>
                <li>4. 后续可在首页和登录页切换多个已绑定群。</li>
              </ol>
            </article>
          </div>
        )
      }
    </section>

    <section id="stack" class="mx-auto max-w-6xl px-6 py-14 lg:px-10">
      <div class="mb-8 flex items-end justify-between gap-6">
        <div>
          <p class="text-sm uppercase tracking-[0.2em] text-rust">Stack</p>
          <h2 class="mt-3 font-serif text-4xl text-ink">先用成熟组合把骨架立住</h2>
        </div>
        <p class="max-w-xl text-sm leading-7 text-ink-soft">
          UI 组件后续以 shadcn/ui 为主，图表用 ECharts，路由和页面主体继续保持 Astro 的内容站优势。
        </p>
      </div>

      <StackGrid sections={stackSections} />
    </section>

    <section id="milestones" class="border-t border-line bg-white/55">
      <div class="mx-auto grid max-w-6xl gap-8 px-6 py-14 lg:grid-cols-[0.8fr_1.2fr] lg:px-10">
        <div>
          <p class="text-sm uppercase tracking-[0.2em] text-rust">Milestones</p>
          <h2 class="mt-3 font-serif text-4xl text-ink">首版只做最关键的三段路</h2>
        </div>

        <div class="space-y-4">
          {milestones.map((item, index) => (
            <article class="rounded-[1.5rem] border border-line bg-white/80 p-5 shadow-[var(--shadow-card)]">
              <div class="flex items-start gap-4">
                <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-mint-soft text-sm font-semibold text-mint">
                  {index + 1}
                </span>
                <p class="pt-1 text-base leading-7 text-ink">{item}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>
