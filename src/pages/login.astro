---
import { ensureBlogSchema } from "@/lib/server/db-bootstrap";
import { getRuntimeEnv } from "@/lib/server/runtime-env";
import { safeGetCurrentAuthSession } from "@/lib/server/safe-auth";
import Layout from "../layouts/Layout.astro";

const nextPath = Astro.url.searchParams.get("next") ?? "/portal";
const env = getRuntimeEnv(Astro.locals);
await ensureBlogSchema(env);
const { authSession } = await safeGetCurrentAuthSession(env, Astro.cookies);
---

<Layout title="登录 | Astrbot Group Blog" description="已有账号登录并进入博客门户">
  <main class="mx-auto max-w-5xl px-4 py-5 sm:px-6 sm:py-8 lg:px-10 lg:py-16">
    <section class="grid gap-4 sm:gap-6 lg:grid-cols-[1fr_0.9fr]">
      <article class="rounded-[1.6rem] border border-line bg-white/85 p-5 shadow-[var(--shadow-card)] sm:rounded-[2rem] sm:p-8">
        <p class="hidden text-sm uppercase tracking-[0.2em] text-rust sm:block">Login</p>
        <h1 class="mt-1 font-serif text-[2rem] text-ink sm:mt-4 sm:text-5xl">已有账号直接登录</h1>
        <p class="mt-3 max-w-3xl text-sm leading-7 text-ink-soft sm:mt-4 sm:text-base sm:leading-8">
          登录成功后会直接跳到“我的博客”门户；如果你是从某个群博客页面跳转过来，则会自动回到那个目标页面。
        </p>

        {
          authSession ? (
            <div class="mt-5 space-y-3 sm:mt-8 sm:space-y-4">
              <div class="rounded-[1.25rem] border border-line bg-paper p-4 sm:rounded-[1.5rem] sm:p-5">
                <div class="text-xs uppercase tracking-[0.16em] text-ink-soft">当前账号</div>
                <div class="mt-2 text-lg font-semibold text-ink">
                  {authSession.account.platform} / {authSession.account.qq_number}
                </div>
                <div class="mt-2 text-sm leading-7 text-ink-soft">
                  已绑定 {authSession.memberships.length} 个群博客。
                </div>
              </div>

              <div class="flex flex-wrap gap-3 sm:gap-4">
                <a
                  class="rounded-full bg-mint px-4 py-2.5 text-sm font-semibold text-white transition hover:opacity-90 sm:px-5 sm:py-3"
                  href={nextPath || "/portal"}
                >
                  继续前往
                </a>
                <a
                  class="rounded-full border border-line px-4 py-2.5 text-sm font-semibold text-ink transition hover:bg-paper-strong sm:px-5 sm:py-3"
                  href="/portal"
                >
                  打开我的博客
                </a>
                <button
                  class="rounded-full border border-line px-4 py-2.5 text-sm font-semibold text-ink transition hover:bg-paper-strong sm:px-5 sm:py-3"
                  data-logout-button
                  type="button"
                >
                  退出登录
                </button>
              </div>
            </div>
          ) : (
            <form class="mt-5 grid gap-4 sm:mt-8 sm:gap-5" data-login-form>
              <label class="block">
                <span class="text-sm font-semibold text-ink">平台</span>
                <input
                  class="mt-2 w-full rounded-2xl border border-line bg-paper px-4 py-3 text-base text-ink outline-none transition focus:border-mint"
                  name="platform"
                  placeholder="例如 telegram / qq / onebot"
                  required
                />
              </label>
              <label class="block">
                <span class="text-sm font-semibold text-ink">平台账号 ID</span>
                <input
                  class="mt-2 w-full rounded-2xl border border-line bg-paper px-4 py-3 text-base text-ink outline-none transition focus:border-mint"
                  name="qqNumber"
                  inputmode="numeric"
                  placeholder="QQ 填 QQ 号，Telegram 填你的 TG UID"
                  required
                />
              </label>
              <label class="block">
                <span class="text-sm font-semibold text-ink">密码</span>
                <input
                  class="mt-2 w-full rounded-2xl border border-line bg-paper px-4 py-3 text-base text-ink outline-none transition focus:border-mint"
                  name="password"
                  type="password"
                  required
                />
              </label>
              <button class="rounded-full bg-mint px-4 py-2.5 text-sm font-semibold text-white transition hover:opacity-90 sm:px-5 sm:py-3">
                登录并进入门户
              </button>
            </form>
          )
        }

        <pre class="mt-5 hidden overflow-auto rounded-[1.25rem] border border-line bg-paper px-4 py-3 text-xs leading-6 text-ink sm:mt-6 sm:rounded-[1.5rem] sm:px-5 sm:py-4 sm:text-sm sm:leading-7" data-login-result></pre>
      </article>

      <article class="rounded-[1.6rem] border border-line bg-paper-strong p-5 sm:rounded-[2rem] sm:p-8">
        <p class="text-xs uppercase tracking-[0.18em] text-ink-soft sm:text-sm sm:tracking-[0.2em]">First Time</p>
        <h2 class="mt-3 font-serif text-xl text-ink sm:mt-4 sm:text-3xl">第一次使用先绑定</h2>
        <p class="mt-3 text-sm leading-7 text-ink-soft sm:mt-4 sm:text-base sm:leading-8">
          如果你还没有在群里完成一次性绑定，不要在这个页面反复试密码，直接去绑定页走一次完整流程。
        </p>
        <div class="mt-5 flex flex-wrap gap-3 sm:mt-8 sm:gap-4">
          <a
            class="rounded-full bg-white px-4 py-2.5 text-sm font-semibold text-ink transition hover:bg-white/80 sm:px-5 sm:py-3"
            href={`/bind?next=${encodeURIComponent(nextPath || "/portal")}`}
          >
            去绑定
          </a>
          <a
            class="rounded-full border border-line px-4 py-2.5 text-sm font-semibold text-ink transition hover:bg-paper sm:px-5 sm:py-3"
            href="/templates"
          >
            查看模板来源
          </a>
        </div>
      </article>
    </section>

    <script is:inline define:vars={{ nextPath }}>
      const showResult = (element, value) => {
        if (!element) return;
        element.classList.remove("hidden");
        element.textContent =
          typeof value === "string" ? value : JSON.stringify(value, null, 2);
      };

      const requestJson = async (url, payload) => {
        const response = await fetch(url, {
          method: "POST",
          credentials: "same-origin",
          headers: {
            "content-type": "application/json",
          },
          body: JSON.stringify(payload),
        });

        const data = await response
          .json()
          .catch(() => ({ ok: false, error: "Invalid JSON response" }));

        return { response, data };
      };

      document.querySelector("[data-login-form]")?.addEventListener("submit", async (event) => {
        event.preventDefault();
        const form = event.currentTarget;
        const formData = new FormData(form);
        const result = document.querySelector("[data-login-result]");

        try {
          const payload = {
            platform: String(formData.get("platform") || ""),
            qqNumber: String(formData.get("qqNumber") || ""),
            password: String(formData.get("password") || ""),
          };
          const { data } = await requestJson("/api/auth/login", payload);
          showResult(result, data);
          if (data.ok) {
            window.location.href = nextPath || "/portal";
          }
        } catch (error) {
          showResult(result, String(error || "请求失败"));
        }
      });

      document.querySelector("[data-logout-button]")?.addEventListener("click", async () => {
        const result = document.querySelector("[data-login-result]");
        try {
          const { data } = await requestJson("/api/auth/logout", {});
          showResult(result, data);
          window.location.href = "/login";
        } catch (error) {
          showResult(result, String(error || "请求失败"));
        }
      });
    </script>
  </main>
</Layout>
