---
import Layout from "../layouts/Layout.astro";

const targetBlog = Astro.url.searchParams.get("blog") ?? "";
const nextPath = Astro.url.searchParams.get("next") ?? "";
---

<Layout title="登录 | Astrbot Group Blog" description="账户登录与群切换入口">
  <main style="max-width:960px;margin:0 auto;padding:32px 20px;line-height:1.7;color:#111;">
    <section style="border:1px solid #ddd;border-radius:16px;padding:24px;background:#fff;">
      <p style="font-size:12px;letter-spacing:0.2em;text-transform:uppercase;color:#666;">Login</p>
      <h1 style="font-size:36px;margin:16px 0 0;">账号绑定与登录</h1>
      <p style="margin:16px 0 0;max-width:720px;">
        首次使用先发起绑定，拿到一次性绑定码后去群里发给 bot；bot 回调放行后，在这里设置密码完成登录。以后直接用 QQ 号和密码登录即可。
      </p>
    </section>

    <section style="display:grid;gap:24px;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));margin-top:24px;">
      <article style="border:1px solid #ddd;border-radius:16px;padding:24px;background:#fff;">
        <p style="font-size:12px;letter-spacing:0.2em;text-transform:uppercase;color:#666;">Bind Step 1</p>
        <h2 style="font-size:28px;margin:16px 0 0;">发起绑定</h2>
        <form style="margin-top:24px;display:grid;gap:16px;" data-bind-start-form>
          <label style="display:block;">
            <span style="font-size:14px;font-weight:600;">博客 slug</span>
            <input
              style="margin-top:8px;width:100%;padding:12px 14px;border:1px solid #ccc;border-radius:12px;"
              name="blogSlug"
              value={targetBlog}
              placeholder="例如 abc123def456"
              required
            />
          </label>
          <label style="display:block;">
            <span style="font-size:14px;font-weight:600;">QQ 号</span>
            <input
              style="margin-top:8px;width:100%;padding:12px 14px;border:1px solid #ccc;border-radius:12px;"
              name="qqNumber"
              inputmode="numeric"
              placeholder="输入你的 QQ 号"
              required
            />
          </label>
          <button style="padding:12px 16px;border-radius:999px;background:#111;color:#fff;border:none;">
            获取绑定码
          </button>
        </form>
        <pre style="margin-top:24px;display:none;overflow:auto;padding:16px;border-radius:12px;background:#f5f5f5;" data-bind-start-result></pre>
      </article>

      <article style="border:1px solid #ddd;border-radius:16px;padding:24px;background:#fff;">
        <p style="font-size:12px;letter-spacing:0.2em;text-transform:uppercase;color:#666;">Bind Step 2</p>
        <h2 style="font-size:28px;margin:16px 0 0;">完成绑定</h2>
        <form style="margin-top:24px;display:grid;gap:16px;" data-bind-finalize-form>
          <label style="display:block;">
            <span style="font-size:14px;font-weight:600;">博客 slug</span>
            <input
              style="margin-top:8px;width:100%;padding:12px 14px;border:1px solid #ccc;border-radius:12px;"
              name="blogSlug"
              value={targetBlog}
              required
            />
          </label>
          <label style="display:block;">
            <span style="font-size:14px;font-weight:600;">QQ 号</span>
            <input
              style="margin-top:8px;width:100%;padding:12px 14px;border:1px solid #ccc;border-radius:12px;"
              name="qqNumber"
              inputmode="numeric"
              required
            />
          </label>
          <label style="display:block;">
            <span style="font-size:14px;font-weight:600;">密码</span>
            <input
              style="margin-top:8px;width:100%;padding:12px 14px;border:1px solid #ccc;border-radius:12px;"
              name="password"
              type="password"
              placeholder="至少 8 位"
            />
          </label>
          <button style="padding:12px 16px;border-radius:999px;background:#111;color:#fff;border:none;">
            完成绑定并登录
          </button>
        </form>
        <pre style="margin-top:24px;display:none;overflow:auto;padding:16px;border-radius:12px;background:#f5f5f5;" data-bind-finalize-result></pre>
      </article>
    </section>

    <section style="display:grid;gap:24px;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));margin-top:24px;">
      <article style="border:1px solid #ddd;border-radius:16px;padding:24px;background:#fff;">
        <p style="font-size:12px;letter-spacing:0.2em;text-transform:uppercase;color:#666;">Login</p>
        <h2 style="font-size:28px;margin:16px 0 0;">已有账号直接登录</h2>
        <form style="margin-top:24px;display:grid;gap:16px;" data-login-form>
          <label style="display:block;">
            <span style="font-size:14px;font-weight:600;">QQ 号</span>
            <input
              style="margin-top:8px;width:100%;padding:12px 14px;border:1px solid #ccc;border-radius:12px;"
              name="qqNumber"
              inputmode="numeric"
              required
            />
          </label>
          <label style="display:block;">
            <span style="font-size:14px;font-weight:600;">密码</span>
            <input
              style="margin-top:8px;width:100%;padding:12px 14px;border:1px solid #ccc;border-radius:12px;"
              name="password"
              type="password"
              required
            />
          </label>
          <button style="padding:12px 16px;border-radius:999px;background:#111;color:#fff;border:none;">
            登录
          </button>
        </form>
        <pre style="margin-top:24px;display:none;overflow:auto;padding:16px;border-radius:12px;background:#f5f5f5;" data-login-result></pre>
      </article>

      <article style="border:1px solid #ddd;border-radius:16px;padding:24px;background:#fff;">
        <div style="display:flex;justify-content:space-between;gap:16px;align-items:flex-start;flex-wrap:wrap;">
          <div>
            <p style="font-size:12px;letter-spacing:0.2em;text-transform:uppercase;color:#666;">Session</p>
            <h2 style="font-size:28px;margin:16px 0 0;">当前会话</h2>
          </div>
          <button
            style="padding:10px 14px;border-radius:999px;border:1px solid #ccc;background:#fff;"
            data-logout-button
            type="button"
          >
            退出登录
          </button>
        </div>

        <div style="margin-top:24px;" data-session-root>
          <div style="padding:16px;border-radius:12px;background:#f5f5f5;">
            当前没有登录态。完成绑定后，页面会自动写入 Cookie 会话。
          </div>
        </div>

        {
          nextPath ? (
            <p style="margin-top:24px;">
              登录成功后可返回：<code>{nextPath}</code>
            </p>
          ) : null
        }
      </article>
    </section>

    <script is:inline define:vars={{ nextPath }}>
      const requestJson = async (url, payload, init = {}) => {
        const response = await fetch(url, {
          method: "POST",
          credentials: "same-origin",
          headers: {
            "content-type": "application/json",
            ...(init.headers || {}),
          },
          body: JSON.stringify(payload),
          ...init,
        });
        const data = await response.json().catch(() => ({ ok: false, error: "Invalid JSON response" }));
        return { response, data };
      };

      const showResult = (element, value) => {
        if (!element) return;
        element.classList.remove("hidden");
        element.textContent = typeof value === "string" ? value : JSON.stringify(value, null, 2);
      };

      const refreshSession = async () => {
        const root = document.querySelector("[data-session-root]");
        if (!root) return;

        const response = await fetch("/api/auth/session", {
          credentials: "same-origin",
        });
        const data = await response.json().catch(() => ({ authenticated: false }));
        if (!data.authenticated) {
          root.innerHTML = '<div class="rounded-2xl bg-paper-strong px-4 py-4 text-base leading-8 text-ink-soft">当前没有登录态。完成绑定后，页面会自动写入 Cookie 会话。</div>';
          return;
        }

        const memberships = Array.isArray(data.memberships) ? data.memberships : [];
        root.innerHTML = `
          <div class="rounded-2xl bg-paper-strong px-4 py-4">
            <div class="text-sm text-ink-soft">已登录 QQ</div>
            <div class="mt-2 text-lg font-semibold text-ink">${data.account.qq_number}</div>
          </div>
          <div class="rounded-2xl bg-paper-strong px-4 py-4">
            <div class="text-sm text-ink-soft">可访问博客</div>
            <ul class="mt-3 space-y-3 text-sm text-ink">
              ${memberships
                .map(
                  (membership) => `
                    <li class="flex items-center justify-between gap-4">
                      <span>${membership.group_name || membership.public_slug}</span>
                      <a class="font-semibold text-mint underline-offset-4 hover:underline" href="/g/${membership.public_slug}">打开</a>
                    </li>`,
                )
                .join("")}
            </ul>
          </div>
        `;
      };

      document.querySelector("[data-bind-start-form]")?.addEventListener("submit", async (event) => {
        event.preventDefault();
        const form = event.currentTarget;
        const formData = new FormData(form);
        const result = document.querySelector("[data-bind-start-result]");
        const payload = {
          blogSlug: String(formData.get("blogSlug") || ""),
          qqNumber: String(formData.get("qqNumber") || ""),
        };
        const { data } = await requestJson("/api/auth/bind/start", payload);
        showResult(
          result,
          data.ok
            ? `绑定码：${data.challenge.bind_code}\n过期时间：${data.challenge.expires_at}\n\n请去目标群里给 bot 发送：/绑定博客 ${data.challenge.bind_code}`
            : data,
        );
      });

      document.querySelector("[data-bind-finalize-form]")?.addEventListener("submit", async (event) => {
        event.preventDefault();
        const form = event.currentTarget;
        const formData = new FormData(form);
        const result = document.querySelector("[data-bind-finalize-result]");
        const payload = {
          blogSlug: String(formData.get("blogSlug") || ""),
          qqNumber: String(formData.get("qqNumber") || ""),
          password: String(formData.get("password") || ""),
        };
        const { data } = await requestJson("/api/auth/bind/finalize", payload);
        showResult(result, data);
        if (data.ok) {
          await refreshSession();
          if (nextPath) window.location.href = nextPath;
        }
      });

      document.querySelector("[data-login-form]")?.addEventListener("submit", async (event) => {
        event.preventDefault();
        const form = event.currentTarget;
        const formData = new FormData(form);
        const result = document.querySelector("[data-login-result]");
        const payload = {
          qqNumber: String(formData.get("qqNumber") || ""),
          password: String(formData.get("password") || ""),
        };
        const { data } = await requestJson("/api/auth/login", payload);
        showResult(result, data);
        if (data.ok) {
          await refreshSession();
          if (nextPath) window.location.href = nextPath;
        }
      });

      document.querySelector("[data-logout-button]")?.addEventListener("click", async () => {
        await requestJson("/api/auth/logout", {});
        await refreshSession();
      });
    </script>
  </main>
</Layout>
