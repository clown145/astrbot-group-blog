---
import { getCurrentAuthSession } from "@/lib/server/request";
import { getRuntimeEnv } from "@/lib/server/runtime-env";
import Layout from "../layouts/Layout.astro";

const env = getRuntimeEnv(Astro.locals);
const current = await getCurrentAuthSession(env, Astro.cookies);
const targetBlog = Astro.url.searchParams.get("blog") ?? "";
const nextPath = Astro.url.searchParams.get("next") ?? "";
---

<Layout title="登录 | Astrbot Group Blog" description="账户登录与群切换入口">
  <main class="mx-auto max-w-4xl px-6 py-16 lg:px-10">
    <section class="rounded-[2rem] border border-line bg-white/80 p-8 shadow-[var(--shadow-card)]">
      <p class="text-sm uppercase tracking-[0.2em] text-rust">Login</p>
      <h1 class="mt-4 font-serif text-4xl text-ink">账号绑定与登录</h1>
      <p class="mt-4 max-w-2xl text-base leading-8 text-ink-soft">
        首次使用先发起绑定，拿到一次性绑定码后去群里发给 bot；bot 回调放行后，在这里设置密码完成登录。以后直接用 QQ 号和密码登录即可。
      </p>
    </section>

    <section class="mt-8 grid gap-6 lg:grid-cols-2">
      <article class="rounded-[2rem] border border-line bg-white/85 p-8 shadow-[var(--shadow-card)]">
        <p class="text-sm uppercase tracking-[0.2em] text-rust">Bind Step 1</p>
        <h2 class="mt-4 font-serif text-3xl text-ink">发起绑定</h2>
        <form class="mt-6 space-y-4" data-bind-start-form>
          <label class="block">
            <span class="text-sm font-semibold text-ink">博客 slug</span>
            <input
              class="mt-2 w-full rounded-2xl border border-line bg-paper px-4 py-3 outline-none transition focus:border-mint"
              name="blogSlug"
              value={targetBlog}
              placeholder="例如 abc123def456"
              required
            />
          </label>
          <label class="block">
            <span class="text-sm font-semibold text-ink">QQ 号</span>
            <input
              class="mt-2 w-full rounded-2xl border border-line bg-paper px-4 py-3 outline-none transition focus:border-mint"
              name="qqNumber"
              inputmode="numeric"
              placeholder="输入你的 QQ 号"
              required
            />
          </label>
          <button class="rounded-full bg-mint px-5 py-3 text-sm font-semibold text-white transition hover:opacity-90">
            获取绑定码
          </button>
        </form>
        <pre class="mt-6 hidden overflow-x-auto rounded-2xl bg-paper-strong px-4 py-4 text-sm leading-7 text-ink" data-bind-start-result></pre>
      </article>

      <article class="rounded-[2rem] border border-line bg-white/85 p-8 shadow-[var(--shadow-card)]">
        <p class="text-sm uppercase tracking-[0.2em] text-rust">Bind Step 2</p>
        <h2 class="mt-4 font-serif text-3xl text-ink">完成绑定</h2>
        <form class="mt-6 space-y-4" data-bind-finalize-form>
          <label class="block">
            <span class="text-sm font-semibold text-ink">博客 slug</span>
            <input
              class="mt-2 w-full rounded-2xl border border-line bg-paper px-4 py-3 outline-none transition focus:border-mint"
              name="blogSlug"
              value={targetBlog}
              required
            />
          </label>
          <label class="block">
            <span class="text-sm font-semibold text-ink">QQ 号</span>
            <input
              class="mt-2 w-full rounded-2xl border border-line bg-paper px-4 py-3 outline-none transition focus:border-mint"
              name="qqNumber"
              inputmode="numeric"
              required
            />
          </label>
          <label class="block">
            <span class="text-sm font-semibold text-ink">密码</span>
            <input
              class="mt-2 w-full rounded-2xl border border-line bg-paper px-4 py-3 outline-none transition focus:border-mint"
              name="password"
              type="password"
              placeholder="至少 8 位"
            />
          </label>
          <button class="rounded-full bg-mint px-5 py-3 text-sm font-semibold text-white transition hover:opacity-90">
            完成绑定并登录
          </button>
        </form>
        <pre class="mt-6 hidden overflow-x-auto rounded-2xl bg-paper-strong px-4 py-4 text-sm leading-7 text-ink" data-bind-finalize-result></pre>
      </article>
    </section>

    <section class="mt-8 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
      <article class="rounded-[2rem] border border-line bg-white/85 p-8 shadow-[var(--shadow-card)]">
        <p class="text-sm uppercase tracking-[0.2em] text-rust">Login</p>
        <h2 class="mt-4 font-serif text-3xl text-ink">已有账号直接登录</h2>
        <form class="mt-6 space-y-4" data-login-form>
          <label class="block">
            <span class="text-sm font-semibold text-ink">QQ 号</span>
            <input
              class="mt-2 w-full rounded-2xl border border-line bg-paper px-4 py-3 outline-none transition focus:border-mint"
              name="qqNumber"
              inputmode="numeric"
              required
            />
          </label>
          <label class="block">
            <span class="text-sm font-semibold text-ink">密码</span>
            <input
              class="mt-2 w-full rounded-2xl border border-line bg-paper px-4 py-3 outline-none transition focus:border-mint"
              name="password"
              type="password"
              required
            />
          </label>
          <button class="rounded-full bg-mint px-5 py-3 text-sm font-semibold text-white transition hover:opacity-90">
            登录
          </button>
        </form>
        <pre class="mt-6 hidden overflow-x-auto rounded-2xl bg-paper-strong px-4 py-4 text-sm leading-7 text-ink" data-login-result></pre>
      </article>

      <article class="rounded-[2rem] border border-line bg-white/85 p-8 shadow-[var(--shadow-card)]">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <p class="text-sm uppercase tracking-[0.2em] text-rust">Session</p>
            <h2 class="mt-4 font-serif text-3xl text-ink">当前会话</h2>
          </div>
          <button
            class="rounded-full border border-line px-4 py-2 text-sm font-semibold text-ink transition hover:bg-paper-strong"
            data-logout-button
            type="button"
          >
            退出登录
          </button>
        </div>

        <div class="mt-6 space-y-5" data-session-root>
          {
            current.authSession ? (
              <>
                <div class="rounded-2xl bg-paper-strong px-4 py-4">
                  <div class="text-sm text-ink-soft">已登录 QQ</div>
                  <div class="mt-2 text-lg font-semibold text-ink">
                    {current.authSession.account.qq_number}
                  </div>
                </div>
                <div class="rounded-2xl bg-paper-strong px-4 py-4">
                  <div class="text-sm text-ink-soft">可访问博客</div>
                  <ul class="mt-3 space-y-3 text-sm text-ink">
                    {current.authSession.memberships.map((membership) => (
                      <li class="flex items-center justify-between gap-4">
                        <span>{membership.group_name || membership.public_slug}</span>
                        <a
                          class="font-semibold text-mint underline-offset-4 hover:underline"
                          href={`/g/${membership.public_slug}`}
                        >
                          打开
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </>
            ) : (
              <div class="rounded-2xl bg-paper-strong px-4 py-4 text-base leading-8 text-ink-soft">
                当前没有登录态。完成绑定后，页面会自动写入 Cookie 会话。
              </div>
            )
          }
        </div>

        {
          nextPath ? (
            <p class="mt-6 text-sm leading-7 text-ink-soft">
              登录成功后可返回：<code>{nextPath}</code>
            </p>
          ) : null
        }
      </article>
    </section>

    <script is:inline define:vars={{ nextPath }}>
      const requestJson = async (url, payload, init = {}) => {
        const response = await fetch(url, {
          method: "POST",
          credentials: "same-origin",
          headers: {
            "content-type": "application/json",
            ...(init.headers || {}),
          },
          body: JSON.stringify(payload),
          ...init,
        });
        const data = await response.json().catch(() => ({ ok: false, error: "Invalid JSON response" }));
        return { response, data };
      };

      const showResult = (element, value) => {
        if (!element) return;
        element.classList.remove("hidden");
        element.textContent = typeof value === "string" ? value : JSON.stringify(value, null, 2);
      };

      const refreshSession = async () => {
        const root = document.querySelector("[data-session-root]");
        if (!root) return;

        const response = await fetch("/api/auth/session", {
          credentials: "same-origin",
        });
        const data = await response.json().catch(() => ({ authenticated: false }));
        if (!data.authenticated) {
          root.innerHTML = '<div class="rounded-2xl bg-paper-strong px-4 py-4 text-base leading-8 text-ink-soft">当前没有登录态。完成绑定后，页面会自动写入 Cookie 会话。</div>';
          return;
        }

        const memberships = Array.isArray(data.memberships) ? data.memberships : [];
        root.innerHTML = `
          <div class="rounded-2xl bg-paper-strong px-4 py-4">
            <div class="text-sm text-ink-soft">已登录 QQ</div>
            <div class="mt-2 text-lg font-semibold text-ink">${data.account.qq_number}</div>
          </div>
          <div class="rounded-2xl bg-paper-strong px-4 py-4">
            <div class="text-sm text-ink-soft">可访问博客</div>
            <ul class="mt-3 space-y-3 text-sm text-ink">
              ${memberships
                .map(
                  (membership) => `
                    <li class="flex items-center justify-between gap-4">
                      <span>${membership.group_name || membership.public_slug}</span>
                      <a class="font-semibold text-mint underline-offset-4 hover:underline" href="/g/${membership.public_slug}">打开</a>
                    </li>`,
                )
                .join("")}
            </ul>
          </div>
        `;
      };

      document.querySelector("[data-bind-start-form]")?.addEventListener("submit", async (event) => {
        event.preventDefault();
        const form = event.currentTarget;
        const formData = new FormData(form);
        const result = document.querySelector("[data-bind-start-result]");
        const payload = {
          blogSlug: String(formData.get("blogSlug") || ""),
          qqNumber: String(formData.get("qqNumber") || ""),
        };
        const { data } = await requestJson("/api/auth/bind/start", payload);
        showResult(
          result,
          data.ok
            ? `绑定码：${data.challenge.bind_code}\n过期时间：${data.challenge.expires_at}\n\n请去目标群里给 bot 发送：/绑定博客 ${data.challenge.bind_code}`
            : data,
        );
      });

      document.querySelector("[data-bind-finalize-form]")?.addEventListener("submit", async (event) => {
        event.preventDefault();
        const form = event.currentTarget;
        const formData = new FormData(form);
        const result = document.querySelector("[data-bind-finalize-result]");
        const payload = {
          blogSlug: String(formData.get("blogSlug") || ""),
          qqNumber: String(formData.get("qqNumber") || ""),
          password: String(formData.get("password") || ""),
        };
        const { data } = await requestJson("/api/auth/bind/finalize", payload);
        showResult(result, data);
        if (data.ok) {
          await refreshSession();
          if (nextPath) window.location.href = nextPath;
        }
      });

      document.querySelector("[data-login-form]")?.addEventListener("submit", async (event) => {
        event.preventDefault();
        const form = event.currentTarget;
        const formData = new FormData(form);
        const result = document.querySelector("[data-login-result]");
        const payload = {
          qqNumber: String(formData.get("qqNumber") || ""),
          password: String(formData.get("password") || ""),
        };
        const { data } = await requestJson("/api/auth/login", payload);
        showResult(result, data);
        if (data.ok) {
          await refreshSession();
          if (nextPath) window.location.href = nextPath;
        }
      });

      document.querySelector("[data-logout-button]")?.addEventListener("click", async () => {
        await requestJson("/api/auth/logout", {});
        await refreshSession();
      });
    </script>
  </main>
</Layout>
